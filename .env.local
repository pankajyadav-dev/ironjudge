# this is demo copy of .env file to run the application create .env in the project root directory and enter the following env variable
HTTPURL="localhost:3000"
REDISURL="redis://api_user:api_pass@localhost:6379/1"
STREAMNAME="submission_stream"
GROUPNAME="x_engine"
CONSUMERNAME="ironjudge"
REDISPAYLOADLEN=1
REDIS_POOL_SIZE=16  #optional